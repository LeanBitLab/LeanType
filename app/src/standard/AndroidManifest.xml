        <service
            android:name="helium314.keyboard.latin.ai.WechatAccessibilityService"
            android:exported="true"
            android:label="@string/ai_candidates_accessibility_service"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
